{% extends "layout/base.html.twig" %}

{% block title %}Kizami - 稼働時間{% endblock %}

{% block body %}
    <h1>稼働時間管理</h1>

    {% if saved %}
        <article class="notice-success">保存しました。</article>
    {% endif %}
    {% if updated %}
        <article class="notice-success">更新しました。</article>
    {% endif %}
    {% if deleted %}
        <article class="notice-success">削除しました。</article>
    {% endif %}

    {% if errors %}
        {% for error in errors %}
            <article class="notice-error">{{ error }}</article>
        {% endfor %}
    {% endif %}

    <h2>表示条件</h2>
    <form method="get" action="/time-entries">
        <label for="date_from">対象期間（From）</label>
        <input id="date_from" type="date" name="date_from" value="{{ filterDateFrom }}">

        <label for="date_to">対象期間（To）</label>
        <input id="date_to" type="date" name="date_to" value="{{ filterDateTo }}">

        <label for="filter_client_id">クライアント</label>
        <select id="filter_client_id" name="client_id">
            <option value="">すべて</option>
            {% for client in clients %}
                <option value="{{ client.id }}" {% if filterClientId == client.id %}selected{% endif %}>
                    {{ client.name }}
                </option>
            {% endfor %}
        </select>

        <button type="submit">絞り込み</button>
    </form>

    <article>
        <strong>{{ filterDateFrom }} 〜 {{ filterDateTo }} 合計:</strong> {{ monthlyTotal }}h
    </article>

    <details class="register-panel" {% if errors or continueRegistration %}open{% endif %}>
        <summary>
            <span class="closed-label">＋ 稼働時間を登録（クリックで開く）</span>
            <span class="open-label">− 稼働時間を登録（クリックで閉じる）</span>
        </summary>
        <form method="post" action="/time-entries">
            {% include "partials/csrf_fields.html.twig" %}
            <label for="date">日付</label>
            <input id="date" type="date" name="date" value="{{ old.date }}" required>

            <label for="client_id">クライアント</label>
            <select id="client_id" name="client_id" required>
                <option value="">選択してください</option>
                {% for client in clients %}
                    <option value="{{ client.id }}" {% if old.client_id == client.id %}selected{% endif %}>
                        {{ client.name }}
                    </option>
                {% endfor %}
            </select>

            <label for="work_category_id">作業分類</label>
            <select id="work_category_id" name="work_category_id" required>
                <option value="">選択してください</option>
                {% for category in workCategories %}
                    <option value="{{ category.id }}" {% if old.work_category_id == category.id %}selected{% endif %}>
                        {{ category.name }}
                    </option>
                {% endfor %}
            </select>

            <label for="start_time">開始</label>
            <select id="start_time" name="start_time" required>
                {% for time in timeOptions %}
                    <option value="{{ time }}" {% if old.start_time == time %}selected{% endif %}>{{ time }}</option>
                {% endfor %}
            </select>

            <label for="end_time">終了</label>
            <select id="end_time" name="end_time" required>
                {% for time in timeOptions %}
                    <option value="{{ time }}" {% if old.end_time == time %}selected{% endif %}>{{ time }}</option>
                {% endfor %}
            </select>

            <label for="comment">コメント</label>
            <textarea id="comment" name="comment" rows="3">{{ old.comment }}</textarea>

            <div class="action-buttons register-actions">
                <button type="submit">登録</button>
                <button type="submit" name="continue_registration" value="1" class="secondary">続けて登録</button>
            </div>
        </form>
    </details>

    <h2>稼働履歴（{{ filterDateFrom }} 〜 {{ filterDateTo }}）</h2>
    {% if timeEntries %}
        <table>
            <thead>
            <tr>
                <th>クライアント</th>
                <th>作業分類</th>
                <th class="number-cell">開始</th>
                <th class="number-cell">終了</th>
                <th class="number-cell">時間 (h)</th>
                <th class="mobile-hide">コメント</th>
                <th>操作</th>
            </tr>
            </thead>
            <tbody>
            {% set groupDate = '' %}
            {% for entry in timeEntries %}
                {% if groupDate != entry.date %}
                    {% set groupDate = entry.date %}
                    <tr class="group-row">
                        <td colspan="7">
                            <strong>{{ groupDate }}</strong>
                            <small>（合計 {{ dailyTotalsByDate[groupDate]|default(0) }}h）</small>
                        </td>
                    </tr>
                {% endif %}
                <tr
                    class="clickable-row"
                    tabindex="0"
                    aria-label="この行を編集"
                    onclick="window.location.href='/time-entries/{{ entry.id }}/edit';"
                    onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); window.location.href='/time-entries/{{ entry.id }}/edit'; }"
                >
                    <td>{{ entry.client_name }}</td>
                    <td>{{ entry.work_category_name }}</td>
                    <td class="number-cell">{{ entry.start_time|slice(0, 5) }}</td>
                    <td class="number-cell">{{ entry.end_time|slice(0, 5) }}</td>
                    <td class="number-cell">{{ entry.hours|number_format(2, '.', '') }}</td>
                    <td class="mobile-hide">{{ entry.comment ?: '-' }}</td>
                    <td>
                        <div class="action-buttons">
                            <form method="post" action="/time-entries/{{ entry.id }}/delete" onclick="event.stopPropagation();">
                                {% include "partials/csrf_fields.html.twig" %}
                                <button
                                    type="submit"
                                    class="outline icon-button danger-icon-button"
                                    onclick="event.stopPropagation(); return confirm('削除しますか？');"
                                    aria-label="削除"
                                    title="削除"
                                >×</button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>まだ登録がありません。</p>
    {% endif %}
{% endblock %}
