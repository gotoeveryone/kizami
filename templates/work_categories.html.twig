{% extends "layout/base.html.twig" %}

{% block title %}Kizami - 作業分類管理{% endblock %}

{% block body %}
    <h1>作業分類管理</h1>

    {% if saved %}
        <article class="notice-success">保存しました。</article>
    {% endif %}
    {% if updated %}
        <article class="notice-success">更新しました。</article>
    {% endif %}
    {% if deleted %}
        <article class="notice-success">削除しました。</article>
    {% endif %}

    {% if errors %}
        {% for error in errors %}
            <article class="notice-error">{{ error }}</article>
        {% endfor %}
    {% endif %}

    <h2>新規追加</h2>
    <form method="post" action="/work-categories">
        {% include "partials/csrf_fields.html.twig" %}
        <label for="name">作業分類名</label>
        <input id="name" type="text" name="name" value="{{ old.name }}" required>

        <label for="sort_order">表示順</label>
        <input id="sort_order" type="number" name="sort_order" value="{{ old.sort_order }}" required>

        <button type="submit">追加</button>
    </form>

    <h2>一覧</h2>
    {% if workCategories %}
        <table>
            <thead>
            <tr>
                <th>作業分類名</th>
                <th>操作</th>
            </tr>
            </thead>
            <tbody>
            {% for workCategory in workCategories %}
                <tr
                    class="clickable-row"
                    tabindex="0"
                    aria-label="この作業分類を編集"
                    onclick="handleRowClick(event, '/work-categories/{{ workCategory.id }}/edit');"
                    onkeydown="handleRowKeydown(event, '/work-categories/{{ workCategory.id }}/edit');"
                >
                    <td>{{ workCategory.name }}</td>
                    <td>
                        <div class="action-buttons">
                            <form method="post" action="/work-categories/{{ workCategory.id }}/delete" onclick="event.stopPropagation();">
                                {% include "partials/csrf_fields.html.twig" %}
                                <button
                                    type="submit"
                                    class="outline icon-button danger-icon-button"
                                    onclick="event.stopPropagation(); return confirm('削除しますか？');"
                                    aria-label="削除"
                                    title="削除"
                                >×</button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>作業分類はまだありません。</p>
    {% endif %}
{% endblock %}
