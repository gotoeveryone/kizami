<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Kizami{% endblock %}</title>
    <link rel="icon" type="image/svg+xml" href="/assets/logo-kizami.svg">
    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"
    >
    <link rel="stylesheet" href="/assets/app.css">
</head>
<body>
<main class="container">
    {% if not (hideTopNav ?? false) %}
        <header class="top-nav">
            <div class="nav-links">
                <a href="/" class="brand">
                    <img src="/assets/logo-kizami.svg" alt="Kizami logo">
                    <span>Kizami</span>
                </a>
                <a href="/time-entries">稼働時間</a>
                <a href="/clients">クライアント</a>
                <a href="/work-categories">作業分類</a>
            </div>
            <form method="post" action="/logout">
                {% include "partials/csrf_fields.html.twig" %}
                <button type="submit" class="logout-compact">ログアウト</button>
            </form>
        </header>
    {% endif %}
    {% block body %}{% endblock %}
</main>
<script>
    function isInteractiveTarget(element) {
        return Boolean(element.closest("a, button, input, select, textarea, form, label, [role='button']"));
    }

    function handleRowClick(event, url) {
        if (isInteractiveTarget(event.target)) {
            return;
        }
        window.location.href = url;
    }

    function handleRowKeydown(event, url) {
        if (isInteractiveTarget(event.target)) {
            return;
        }

        if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            window.location.href = url;
        }
    }
</script>
</body>
</html>
